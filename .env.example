# Comma-separated connection profile names
PRT_DB_MCP_CONNECTIONS=local

# Default profile when a tool omits "connection"
PRT_DB_MCP_DEFAULT_CONNECTION=local

# Local PrtDatabaseService (docker-compose on localhost:54321)
PRT_DB_MCP_LOCAL_URL=postgresql://postgres:password@localhost:54321/postgres

# Optional: read-only role (recommended after running scripts/create_readonly_role.sql)
# PRT_DB_MCP_LOCAL_URL=postgresql://prt_mcp_readonly:prt_mcp_readonly@localhost:54321/postgres

PRT_DB_MCP_MAX_ROWS=100
PRT_DB_MCP_HARD_MAX_ROWS=500
PRT_DB_MCP_STATEMENT_TIMEOUT_MS=10000
PRT_DB_MCP_ALLOW_WRITE=false

# Path to merged schema catalog (optional)
# PRT_DB_MCP_CATALOG_PATH=/path/to/catalog/generated.json
